{
  "name": "openclaw-event-server-plugin",
  "version": "1.0.1",
  "description": "OpenClaw plugin for capturing and broadcasting events via webhooks",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "config.example.json",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "lint": "eslint src tests --ext .ts",
    "toolguard:replay": "node dist/tools/replay-tool-guard.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "events",
    "webhooks",
    "automation"
  ],
  "author": "OpenClaw Community",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@types/ws": "^8.5.10",
    "axios": "^1.6.5",
    "uuid": "^9.0.1",
    "ws": "^8.16.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}

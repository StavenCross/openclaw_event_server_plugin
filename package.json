{
  "name": "event-server-plugin",
  "version": "1.1.2",
  "description": "OpenClaw plugin for capturing and broadcasting events via webhooks",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "CHANGELOG.md",
    "config.example.json",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "lint": "eslint src tests --ext .ts",
    "verify:release": "npm run lint && npm run build && npm test -- --runInBand",
    "verify:ci": "CI=1 npm run verify:release",
    "verify:release-lane": "./scripts/verify-release-lane.sh",
    "release": "./scripts/release.sh",
    "toolguard:replay": "node dist/tools/replay-tool-guard.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "events",
    "webhooks",
    "automation"
  ],
  "author": "OpenClaw Community",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/StavenCross/openclaw_event_server_plugin"
  },
  "bugs": {
    "url": "https://github.com/StavenCross/openclaw_event_server_plugin/issues"
  },
  "homepage": "https://github.com/StavenCross/openclaw_event_server_plugin#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.37",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@types/ws": "^8.5.10",
    "axios": "^1.6.5",
    "uuid": "^11.1.0",
    "ws": "^8.16.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
